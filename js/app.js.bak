// ═══════════════════════════════════════════
//   ESTADO GLOBAL
// ═══════════════════════════════════════════
let planData  = null;  // { [sheetName]: { cedula, nombre, rows: [{zona, actividad, dia}] } }
let visitData = null;  // Map: "CEDULA|ZONA|DIA" -> count
let allRows   = [];    // filas actuales en pantalla

// ═══════════════════════════════════════════
//   EVENTOS DE CARGA DE ARCHIVOS
// ═══════════════════════════════════════════
document.getElementById('file-planeador').addEventListener('change', async e => {
  const file = e.target.files[0];
  if (!file) return;
  document.getElementById('name-planeador').textContent = '⏳ Procesando...';
  await parsePlaneador(file);
  document.getElementById('name-planeador').textContent = '✓ ' + file.name;
  document.getElementById('card-planeador').classList.add('loaded');
  tryEnableControls();
});

document.getElementById('file-visitas').addEventListener('change', async e => {
  const file = e.target.files[0];
  if (!file) return;
  document.getElementById('name-visitas').textContent = '⏳ Procesando...';
  await parseVisitas(file);
  document.getElementById('name-visitas').textContent = '✓ ' + file.name;
  document.getElementById('card-visitas').classList.add('loaded');
  tryEnableControls();
});

// ═══════════════════════════════════════════
//   PARSEAR PLANEADOR EXCEL
// ═══════════════════════════════════════════
async function parsePlaneador(file) {
  const data = await file.arrayBuffer();
  const wb   = XLSX.read(data, { type: 'array', cellStyles: true });
  planData   = {};

  const GREEN_RGB   = ['FF92D050', 'FF8ED965'];
  const GREEN_THEME = [9]; // theme index 9 = verde en Office

  for (const sheetName of wb.SheetNames) {
    const ws = wb.Sheets[sheetName];

    // Nombre (F6) y cédula (F7)
    const nombreCell = ws['F6'];
    const cedulaCell = ws['F7'];
    if (!nombreCell || !cedulaCell) continue;

    const nombre = String(nombreCell.v || '').trim();
    const cedula = String(Math.round(Number(cedulaCell.v)) || '').trim();

    // Fila 17: mapa col → día del mes
    const dateMap = {};
    for (let col = 7; col <= 50; col++) {
      const addr = XLSX.utils.encode_cell({ r: 16, c: col - 1 });
      const cell = ws[addr];
      if (cell && cell.v !== undefined && cell.v !== null) {
        try { dateMap[col] = Math.round(Number(cell.v)); } catch {}
      }
    }

    // Filas 18+: buscar X verdes
    const rows  = [];
    const range = XLSX.utils.decode_range(ws['!ref'] || 'A1:A1');

    for (let r = 17; r <= range.e.r; r++) {
      const zonaCell = ws[XLSX.utils.encode_cell({ r, c: 4 })]; // col E
      const actCell  = ws[XLSX.utils.encode_cell({ r, c: 5 })]; // col F
      if (!zonaCell) continue;

      const zona     = String(zonaCell.v || '').trim();
      const actividad = actCell ? String(actCell.v || '').trim() : '';

      for (let col = 7; col <= 50; col++) {
        const addr = XLSX.utils.encode_cell({ r, c: col - 1 });
        const cell = ws[addr];
        if (!cell || String(cell.v).toUpperCase() !== 'X') continue;

        const day = dateMap[col];
        if (!day || !zona) continue;

        // Verificar color verde
        let isGreen = false;
        const s = cell.s;
        if (s && s.fgColor) {
          const fc = s.fgColor;
          if (fc.rgb   && GREEN_RGB.includes(fc.rgb.toUpperCase())) isGreen = true;
          if (fc.theme !== undefined && GREEN_THEME.includes(fc.theme)) isGreen = true;
        }

        if (isGreen) {
          rows.push({ zona: zona.toUpperCase(), actividad, dia: day });
        }
      }
    }

    if (rows.length > 0) {
      planData[sheetName] = { nombre, cedula, rows };
    }
  }
}

// ═══════════════════════════════════════════
//   PARSEAR CSV DE VISITAS
// ═══════════════════════════════════════════
async function parseVisitas(file) {
  visitData = new Map();
  const text  = await file.text();
  const lines = text.split('\n').filter(l => l.trim());
  if (lines.length < 2) return;

  // Detectar separador automáticamente
  const sep     = lines[0].includes(';') ? ';' : ',';
  const headers = lines[0].replace(/^\uFEFF/, '').split(sep).map(h => h.trim().replace(/^"|"$/g, ''));

  const colFecha  = headers.indexOf('FECHA');
  const colRuta   = headers.indexOf('RUTA');
  const colCedula = headers.indexOf('CEDULA');

  for (let i = 1; i < lines.length; i++) {
    const parts = lines[i].split(sep).map(p => p.trim().replace(/^"|"$/g, ''));
    if (parts.length < 5) continue;

    const fechaStr  = parts[colFecha] || '';
    const dateMatch = fechaStr.match(/(\d{4}-\d{2}-\d{2})/);
    if (!dateMatch) continue;

    const dia    = parseInt(dateMatch[1].split('-')[2]);
    const zona   = (parts[colRuta]   || '').toUpperCase().trim();
    const cedula = (parts[colCedula] || '').trim();
    if (!zona || !cedula) continue;

    const key = `${cedula}|${zona}|${dia}`;
    visitData.set(key, (visitData.get(key) || 0) + 1);
  }
}

// ═══════════════════════════════════════════
//   HABILITAR CONTROLES
// ═══════════════════════════════════════════
function tryEnableControls() {
  if (!planData || !visitData) return;

  const sel = document.getElementById('sel-persona');
  sel.innerHTML = '<option value="">— Selecciona una persona —</option>';

  for (const [sheet, info] of Object.entries(planData)) {
    const opt = document.createElement('option');
    opt.value       = sheet;
    opt.textContent = `${info.nombre} (CC ${info.cedula})`;
    sel.appendChild(opt);
  }

  sel.disabled = false;
  document.getElementById('sel-mes').disabled  = false;
  document.getElementById('sel-mes').innerHTML = '<option value="3">Marzo 2026</option>';
  document.getElementById('btn-analizar').disabled = false;
}

// ═══════════════════════════════════════════
//   ANALIZAR PERSONA SELECCIONADA
// ═══════════════════════════════════════════
function analizarPersona() {
  const sheet = document.getElementById('sel-persona').value;
  if (!sheet || !planData[sheet]) return;

  const persona = planData[sheet];

  // Cruzar planeado vs realizado
  allRows = persona.rows.map(row => {
    const key   = `${persona.cedula}|${row.zona}|${row.dia}`;
    const count = visitData.get(key) || 0;
    return { ...row, visitas: count, cumple: count > 0 };
  }).sort((a, b) => a.dia - b.dia);

  const total    = allRows.length;
  const cumple   = allRows.filter(r => r.cumple).length;
  const noCumple = total - cumple;
  const pct      = total > 0 ? Math.round(cumple / total * 100) : 0;

  // Cabecera persona
  const initials = persona.nombre.split(' ').slice(0, 2).map(w => w[0]).join('');
  document.getElementById('avatar').textContent          = initials;
  document.getElementById('persona-nombre').textContent  = persona.nombre;
  document.getElementById('persona-meta').textContent    = `CC ${persona.cedula} · ${total} visitas planeadas · Marzo 2026`;

  // Estadísticas
  document.getElementById('stat-total').textContent    = total;
  document.getElementById('stat-cumple').textContent   = cumple;
  document.getElementById('stat-nocumple').textContent = noCumple;
  document.getElementById('stat-pct').textContent      = pct + '%';

  const bar = document.getElementById('progress-bar');
  bar.style.width      = pct + '%';
  bar.style.background = pct >= 70 ? 'var(--green)' : pct >= 40 ? 'var(--amber)' : 'var(--red)';

  document.getElementById('table-title').textContent   = `Detalle · ${persona.nombre}`;

  renderTabla(allRows);

  document.getElementById('results').style.display     = 'block';
  document.getElementById('empty-state').style.display = 'none';

  // Resetear filtros
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-btn').classList.add('active');
}

// ═══════════════════════════════════════════
//   RENDERIZAR TABLA
// ═══════════════════════════════════════════
function renderTabla(rows) {
  const tbody = document.getElementById('tabla-body');
  tbody.innerHTML = '';

  if (rows.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--muted)">Sin datos para mostrar</td></tr>';
    return;
  }

  for (const row of rows) {
    const tr         = document.createElement('tr');
    const badgeClass = row.cumple ? 'cumple'            : 'nocumple';
    const badgeText  = row.cumple ? '✅ Cumplió'        : '❌ No cumplió';
    const countStyle = row.cumple ? 'color:var(--green)' : 'color:var(--red)';

    tr.innerHTML = `
      <td><span class="day-cell">${row.dia}</span></td>
      <td><span class="zona-cell">${row.zona}</span></td>
      <td style="color:var(--muted);font-size:0.82rem">${row.actividad || '—'}</td>
      <td><span class="visits-count" style="${countStyle}">${row.visitas}</span></td>
      <td><span class="badge ${badgeClass}">${badgeText}</span></td>
    `;
    tbody.appendChild(tr);
  }
}

// ═══════════════════════════════════════════
//   FILTRAR TABLA
// ═══════════════════════════════════════════
function filtrarTabla(tipo, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  let filtered = allRows;
  if (tipo === 'cumple')   filtered = allRows.filter(r => r.cumple);
  if (tipo === 'nocumple') filtered = allRows.filter(r => !r.cumple);
  renderTabla(filtered);
}
